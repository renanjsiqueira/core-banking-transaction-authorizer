            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": {\n    \"value\": 15.00,\n    \"currency\": \"BRL\"\n  }\n}"
