        {
          "name": "Seed account through LocalStack SQS",
          "description": "Optional local setup request. Run it with LocalStack and listener up, then wait a few seconds for the listener to import `{{accountId}}`.",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('accountId', pm.environment.get('seedAccountId'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('localstack accepted message', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "Action",
                  "value": "SendMessage",
                  "type": "text"
                },
                {
                  "key": "Version",
                  "value": "2012-11-05",
                  "type": "text"
                },
                {
                  "key": "MessageBody",
                  "value": "{\"account\":{\"id\":\"{{seedAccountId}}\",\"owner\":\"{{seedOwnerId}}\",\"created_at\":\"1634874339\",\"status\":\"ENABLED\"}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{localstackBaseUrl}}/{{queuePath}}",
              "host": [
                "{{localstackBaseUrl}}"
              ],
              "path": [
                "{{queuePath}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Authorization",
      "item": [
        {
          "name": "Credit approved",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('creditTransactionId', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('transaction succeeded', () => pm.expect(json.transaction.status).to.eql('SUCCEEDED'));",
                  "pm.test('transaction type is CREDIT', () => pm.expect(json.transaction.type).to.eql('CREDIT'));",
                  "pm.test('account id matches', () => pm.expect(json.account.id).to.eql(pm.environment.get('accountId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": {\n    \"value\": 100.00,\n    \"currency\": \"BRL\"\n  }\n}"
            },
            "url": {
              "raw": "{{apiBaseUrl}}/transactions/{{creditTransactionId}}",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "transactions",
                "{{creditTransactionId}}"
              ]
            }
          }
        },
