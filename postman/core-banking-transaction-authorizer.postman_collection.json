                  "const json = pm.response.json();",
                  "pm.test('transaction succeeded', () => pm.expect(json.transaction.status).to.eql('SUCCEEDED'));",
                  "pm.environment.set('replayBalanceAmount', String(json.account.balance.amount));"
                ]
