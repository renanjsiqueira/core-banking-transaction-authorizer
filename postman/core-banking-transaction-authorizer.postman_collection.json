{
  "info": {
    "_postman_id": "d46c1bd8-2a47-49cb-9874-7e9579e5cc21",
    "name": "Core Banking - Transaction Authorizer",
    "description": "Collection for local validation of the Core Banking transaction authorizer case. Import the `Core Banking - Local` environment, start the stack, optionally run `Seed account through LocalStack SQS`, wait for the listener to import the account, then run the authorization scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const env = pm.environment;",
          "const uuid = () => pm.variables.replaceIn('{{$guid}}');",
          "",
          "if (!env.get('accountId')) {",
          "  env.set('accountId', env.get('seedAccountId') || uuid());",
          "}",
          "if (!env.get('seedAccountId')) {",
          "  env.set('seedAccountId', env.get('accountId') || uuid());",
          "}",
          "if (!env.get('seedOwnerId')) {",
          "  env.set('seedOwnerId', uuid());",
          "}",
          "if (!env.get('missingAccountId')) {",
          "  env.set('missingAccountId', '00000000-0000-4000-8000-000000000000');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "apiBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "listenerBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "localstackBaseUrl",
      "value": "http://localhost:4566"
    }
  ],
