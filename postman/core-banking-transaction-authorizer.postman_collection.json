              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "transactions",
                "{{replayTransactionId}}"
              ]
            }
          }
        },
        {
          "name": "Idempotent replay - same payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('same transaction id', () => pm.expect(json.transaction.id).to.eql(pm.environment.get('replayTransactionId')));",
                  "pm.test('same resulting balance snapshot', () => pm.expect(String(json.account.balance.amount)).to.eql(pm.environment.get('replayBalanceAmount')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
